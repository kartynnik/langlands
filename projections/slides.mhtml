.reveal { font-family: Inter, sans-serif; color: rgb(44, 62, 80); }

.reveal h1, .reveal h2, .reveal h3, .reveal h4 { font-family: Inter, sans-s=
erif; text-transform: none; font-weight: 600; color: rgb(26, 37, 47); lette=
r-spacing: -0.02em; }

