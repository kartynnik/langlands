.minimal-text { font-size: 0.9em !important; color: rgb(113, 128, 150) !imp=
ortant; margin-top: 15px !important; }

@keyframes explode {=20
  0% { fill: rgb(52, 152, 219); r: 10; opacity: 1; }
  10% { fill: rgb(231, 76, 60); r: 15; opacity: 1; }
  30% { fill: rgb(231, 76, 60); r: 500; opacity: 0.5; }
  100% { fill: rgb(231, 76, 60); r: 500; opacity: 0; }
}

@keyframes shockwave {=20
  0% { stroke: rgb(231, 76, 60); stroke-width: 2; opacity: 1; stroke-dashof=
fset: 100; }
  100% { stroke: rgb(231, 76, 60); stroke-width: 8; opacity: 0; stroke-dash=
offset: 0; }
}

@keyframes pulse-node {=20
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

@keyframes phase-shift {=20
  0% { stroke-dashoffset: 200; }
  100% { stroke-dashoffset: 0; }
